ForegroundLink={{ secondary.hex }}
ForegroundNegative={{ error.hex }}
ForegroundNeutral={{ primary.desaturate(0.2).hex }}
ForegroundNormal={{ foreground.hex }}
ForegroundPositive={{ success.hex }}
ForegroundVisited={{ muted.hex }}

